      "parameters": {
        "jsCode": "const ctx = $('Parse payload').first().json;\nconst issue_id = ctx.value;\nconst rows = $input.all().map(x => x.json);\nconst issue = rows.find(r => r.issue_id === issue_id);\nif (!issue) return [{ json: { __notFound: true, issue_id } }];\nreturn [{ json: {\n  ...issue,\n  status: 'closed',\n  updated_at: new Date().toISOString(),\n}}];"
      },
