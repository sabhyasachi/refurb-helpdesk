      "parameters": {
        "jsCode": "const ctx = $('Parse payload').first().json;\nconst updated = $json;\nconst blocks = (ctx.original_blocks || []).filter(b => b.type !== 'actions');\nblocks.push({\n  type: 'context',\n  elements: [{ type: 'mrkdwn', text: `✅ Closed by <@${ctx.user_id}> at ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })}` }],\n});\nreturn [{ json: {\n  replace_original: true,\n  text: `✅ ${updated.issue_id} closed`,\n  blocks,\n  response_url: ctx.response_url,\n}}];"
      },
