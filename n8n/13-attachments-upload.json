    {
      "parameters": {
        "jsCode": "// Extract fields from multipart form\nconst webhookData = $input.first();\nconst body = webhookData.json.body || {};\n\nconst issue_id  = body.issue_id  || '';\nconst author_id = body.author_id || '';\n\nif (!issue_id)  throw new Error('MISSING_ISSUE_ID');\nif (!author_id) throw new Error('MISSING_AUTHOR_ID');\n\n// Binary file is in webhookData.binary\nconst binaryKeys = Object.keys(webhookData.binary || {});\nif (!binaryKeys.length) throw new Error('NO_FILE');\n\nconst fileKey = binaryKeys[0];\nconst file    = webhookData.binary[fileKey];\n\n// 25 MB limit\nif (file.fileSize && file.fileSize > 25 * 1024 * 1024) {\n  throw new Error('FILE_TOO_LARGE');\n}\n\nconst safeName = (file.fileName || 'upload').replace(/[^a-zA-Z0-9._-]/g, '_');\n\nreturn [{ json: { issue_id, author_id, fileName: safeName, mimeType: file.mimeType || 'application/octet-stream' }, binary: { file: file } }];"
      },
      "id": "m3000001-0002-0002-0002-000000000002",
      "name": "Validate + extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
