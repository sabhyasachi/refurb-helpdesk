          "id": "REPLACE_WITH_GOOGLE_OAUTH_CRED_ID",
          "name": "RefurbHelpdesk OAuth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const uploadResult = $('Upload to Drive').first().json;\nconst prevData     = $('Validate + extract').first().json;\nconst attachments  = $('Read attachments').all().map(x => x.json);\n\nconst aNums = attachments\n  .map(a => parseInt((a.attachment_id || '').replace('ATT-', ''), 10))\n  .filter(n => !isNaN(n));\nconst next = aNums.length ? Math.max(...aNums) + 1 : 1;\nconst attachment_id = 'ATT-' + String(next).padStart(4, '0');\n\nconst fileId = uploadResult.id;\nconst viewUrl = `https://drive.google.com/file/d/${fileId}/view`;\n\nreturn [{ json: {\n  attachment_id,\n  issue_id:    prevData.issue_id,\n  author_id:   prevData.author_id,\n  file_name:   prevData.fileName,\n  file_url:    viewUrl,\n  drive_id:    fileId,\n  mime_type:   prevData.mimeType,\n  created_at:  new Date().toISOString(),\n}}];"
      },
